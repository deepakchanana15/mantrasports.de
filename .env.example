# ─────────────────────────────────────────────────────────────
# MANTRA SPORTS DE — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Mantra Sports DE"
NEXT_PUBLIC_REGION=de

# ── Database ─────────────────────────────────────────────────
# Local development (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/mantra_sports_de

# Production (Google Cloud SQL via Firebase)
# DATABASE_URL=postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE

# ── Authentication ────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=TO_BE_GENERATED

# ── Email / SMTP ─────────────────────────────────────────────
SMTP_HOST=TO_BE_PROVIDED
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=TO_BE_PROVIDED
SMTP_PASS=TO_BE_PROVIDED
SMTP_FROM="Mantra Sports DE <noreply@mantrasports.de>"

# Enquiry destination — all enquiries are sent here
EMAIL_TO=TO_BE_PROVIDED

# ── WhatsApp ─────────────────────────────────────────────────
# International format without +, e.g. 4917600000000
NEXT_PUBLIC_WHATSAPP_NUMBER=TO_BE_PROVIDED

# ── File Uploads ─────────────────────────────────────────────
# Local development — files stored in /public/uploads
UPLOAD_MAX_SIZE_MB=10

# Production — uncomment and configure Google Cloud Storage
# GCS_BUCKET_NAME=TO_BE_PROVIDED
# GCS_PROJECT_ID=TO_BE_PROVIDED

# ── Payments (Future — DO NOT ENABLE YET) ────────────────────
# PAYPAL_CLIENT_ID=TO_BE_PROVIDED
# PAYPAL_CLIENT_SECRET=TO_BE_PROVIDED
# PAYPAL_MODE=sandbox

# ── Analytics (Future) ───────────────────────────────────────
# NEXT_PUBLIC_GA_ID=TO_BE_PROVIDED

# ── Firebase ─────────────────────────────────────────────────
# FIREBASE_PROJECT_ID=TO_BE_PROVIDED
